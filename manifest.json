{
  "manifest_version": 3,
  "name": "OTPilot",
  "version": "0.0.4",
  "description": "Detects 2FA setup pages and saves accounts in one click. Auto-fills TOTP codes on login pages — no phone needed.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*/*"],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OTPilot",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["totp.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
