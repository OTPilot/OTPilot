DATABASE_URL=postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
RUST_LOG=api=debug,tower_http=debug
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_SECRET=<from Supabase → Settings → API → JWT Settings>
SUPABASE_SERVICE_ROLE_KEY=<from Supabase → Settings → API → service_role key>
PORT=3000

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PERSONAL_PRICE_ID=price_...
SUCCESS_URL=http://localhost:5173/dashboard?upgraded=1
CANCEL_URL=http://localhost:5173/dashboard

RESEND_API_KEY=re_...
FROM_EMAIL=noreply@otpilot.app
SEND_EMAILS=false   # set to true in production to actually send via Resend

SENTRY_DSN=https://...@sentry.io/...   # optional — omit to disable Sentry

# Domain icon (favicon) storage — Cloudflare R2 (S3-compatible) with a PUBLIC bucket.
# Omit these to disable the /icons feature (the endpoint then returns "none" for every domain).
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=otpilot-icons
S3_ACCESS_KEY_ID=<r2 access key id>
S3_SECRET_ACCESS_KEY=<r2 secret access key>
S3_REGION=auto
S3_PUBLIC_BASE_URL=https://icons.otpilot.app   # r2.dev URL or custom domain serving the bucket
